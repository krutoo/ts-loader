{
  "name": "@krutoo/ts-loader",
  "version": "0.0.0",
  "type": "module",
  "description": "TypeScript loader with typecheck",
  "author": "Dmitriy Petrov <dima.krutoo@yandex.ru>",
  "keywords": [
    "typescript",
    "typecheck",
    "loader"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krutoo/ts-loader.git"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24.6.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.5.1",
      "onFail": "error"
    }
  },
  "scripts": {
    "fmt": "prettier . --write",
    "check": "tsc -p . --noEmit",
    "build": "node ./scripts/build.ts"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.12.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/register.js"
  }
}
